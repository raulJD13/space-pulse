    -- dbt/models/staging/stg_near_earth_objects.sql

WITH raw AS (
    SELECT * FROM `default`.`neows_raw`
),

cleaned AS (
    SELECT
        -- ClickHouse detecta los JSON nested como Tuples/Maps. 
        -- Extraemos los campos que nos importan.
        JSONExtractString(raw.id) AS neo_id,
        JSONExtractString(raw.name) AS neo_name,
        
        -- Diámetro
        JSONExtractFloat(JSONExtractRaw(JSONExtractRaw(raw.estimated_diameter, 'kilometers'), 'estimated_diameter_max')) AS diameter_max_km,
        
        -- Booleans
        JSONExtractBool(raw.is_potentially_hazardous_asteroid) AS is_hazardous,
        
        -- Datos de acercamiento (que aplanamos en Python)
        JSONExtractFloat(raw._velocity_km_s) AS velocity_km_s,
        JSONExtractFloat(raw._miss_distance_lunar) AS miss_distance_lunar,
        toDate(JSONExtractString(raw._close_approach_date)) AS close_approach_date,
        
        -- Metadatos
        toDate(JSONExtractString(raw._ingestion_date)) AS ingested_at
        
    FROM raw
    WHERE neo_id != '' -- Filtramos posibles filas vacías
)

