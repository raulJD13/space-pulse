  create view `space_pulse_dev_staging`.`stg_solar_flares` 
  
    
    
  as (
    -- dbt/models/staging/stg_solar_flares.sql

WITH raw AS (
    SELECT json FROM `default`.`donki_flares_raw`
),

-- Extraemos el array de flares y creamos una fila independiente por cada uno
exploded AS (
    SELECT arrayJoin(JSONExtractArrayRaw(JSONExtractRaw(JSONExtractRaw(json, 'data'), 'flares'))) AS flare_json
    FROM raw
    -- Nos aseguramos de que el JSON realmente tiene la sección 'flares'
    WHERE JSONHas(JSONExtractRaw(json, 'data'), 'flares')
),

cleaned AS (
    SELECT
        JSONExtractString(flare_json, 'flrID') AS flare_id,
        CAST(JSONExtractString(flare_json, 'beginTime') AS DateTime) AS begin_time,
        CAST(JSONExtractString(flare_json, 'peakTime') AS DateTime) AS peak_time,
        CAST(JSONExtractString(flare_json, 'endTime') AS DateTime) AS end_time,
        
        -- Extraemos la clase entera (ej: "M1.2")
        JSONExtractString(flare_json, 'classType') AS flare_class,        
        
        -- Separamos la letra (M) y el número (1.2) para poder ordenarlos luego
        LEFT(JSONExtractString(flare_json, 'classType'), 1) AS flare_class_letter,
        CAST(SUBSTRING(JSONExtractString(flare_json, 'classType'), 2) AS Float32) AS flare_class_number,
        
        JSONExtractString(flare_json, 'sourceLocation') AS source_location
    FROM exploded
)

SELECT * FROM cleaned 
WHERE flare_id != ''
