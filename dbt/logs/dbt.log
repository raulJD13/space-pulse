        CAST(raw._velocity_km_s AS Float64) AS velocity_km_s,
        CAST(raw._miss_distance_lunar AS Float64) AS miss_distance_lunar,
        CAST(raw._close_approach_date AS Date) AS close_approach_date,
        CAST(raw._ingestion_date AS Date) AS ingested_at
        
    FROM raw
    WHERE raw.id IS NOT NULL AND raw.id != ''
)

