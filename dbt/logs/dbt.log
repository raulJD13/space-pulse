            WHEN 'X' THEN 5
            WHEN 'M' THEN 4
            WHEN 'C' THEN 3
            WHEN 'B' THEN 2
            ELSE 1
        END AS severity_numeric,
        
        -- Asignamos la etiqueta de severidad para el Dashboard
        CASE flare_class_letter
            WHEN 'X' THEN 'CRITICAL'
            WHEN 'M' THEN 'HIGH'
            WHEN 'C' THEN 'MEDIUM'
            ELSE 'LOW'
        END AS severity_label
        
    FROM `space_pulse_dev_staging`.`stg_solar_flares`
)

