WITH raw AS (
    -- Ahora leemos de la columna 'json' que nos da el formato JSONAsString
    SELECT json FROM `default`.`neows_raw`
),

cleaned AS (
    SELECT
        -- JSON_VALUE usa rutas estilo JSONPath ('$.campo') para navegar por el JSON
        JSON_VALUE(json, '$.id') AS neo_id,
        JSON_VALUE(json, '$.name') AS neo_name,
        
        -- Magia: podemos navegar por diccionarios anidados súper fácil
        CAST(JSON_VALUE(json, '$.estimated_diameter.kilometers.estimated_diameter_max') AS Float64) AS diameter_max_km,
        
        CAST(JSON_VALUE(json, '$.is_potentially_hazardous_asteroid') AS Bool) AS is_hazardous,
        
        -- Variables calculadas en Python
        CAST(JSON_VALUE(json, '$._velocity_km_s') AS Float64) AS velocity_km_s,
        CAST(JSON_VALUE(json, '$._miss_distance_lunar') AS Float64) AS miss_distance_lunar,
        CAST(JSON_VALUE(json, '$._close_approach_date') AS Date) AS close_approach_date,
        CAST(JSON_VALUE(json, '$._ingestion_date') AS Date) AS ingested_at
        
    FROM raw
    WHERE JSON_VALUE(json, '$.id') IS NOT NULL AND JSON_VALUE(json, '$.id') != ''
)

