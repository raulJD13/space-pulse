    -- dbt/models/staging/stg_solar_flares.sql

WITH raw AS (
    SELECT json FROM `default`.`donki_flares_raw`
),

-- Extraemos el array directamente de la clave 'flares'
exploded AS (
    SELECT arrayJoin(JSONExtractArrayRaw(JSONExtractRaw(json, 'flares'))) AS flare_json
    FROM raw
    WHERE JSONHas(json, 'flares')
),

cleaned AS (
    SELECT
        JSONExtractString(flare_json, 'flrID') AS flare_id,
        CAST(JSONExtractString(flare_json, 'beginTime') AS DateTime) AS begin_time,
        
        -- A veces no hay peakTime o endTime, usamos un ifNull para no romper
        CAST(ifNull(JSONExtractString(flare_json, 'peakTime'), JSONExtractString(flare_json, 'beginTime')) AS DateTime) AS peak_time,
        CAST(ifNull(JSONExtractString(flare_json, 'endTime'), JSONExtractString(flare_json, 'beginTime')) AS DateTime) AS end_time,
        
        JSONExtractString(flare_json, 'classType') AS flare_class,        
        LEFT(JSONExtractString(flare_json, 'classType'), 1) AS flare_class_letter,
        
        -- Si no hay número de clase, ponemos 0.0
        CAST(ifNull(SUBSTRING(JSONExtractString(flare_json, 'classType'), 2), '0.0') AS Float32) AS flare_class_number,
        
        JSONExtractString(flare_json, 'sourceLocation') AS source_location
    FROM exploded
)

SELECT * FROM cleaned 
WHERE flare_id != ''
